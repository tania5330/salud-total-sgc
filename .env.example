# ============================================================
# .env.example — Variables de entorno del sistema Salud Total
# COPIAR este archivo como .env y completar los valores reales
# ⚠️  NUNCA subir el archivo .env al control de versiones
# ============================================================

# ── Base de Datos PostgreSQL ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=salud_total
DB_USER=postgres
DB_PASSWORD=tu_password_seguro_aqui

# ── Seguridad de la Aplicación ──────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=reemplaza-con-una-clave-secreta-muy-larga-y-aleatoria

# Duración de sesión en horas (recomendado: 8 para jornada laboral)
JWT_EXPIRE_HOURS=8

# ── Backup ──────────────────────────────────────────────────
# Ruta donde se guardarán los archivos de backup
BACKUP_DIR=./backups

# ── Modo de Desarrollo ──────────────────────────────────────
# Cambiar a false en producción
DEBUG=false

# ── Streamlit (opcional, se puede configurar en .streamlit/config.toml)
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
